# --- REST Server ---
RESTSERVER_HOST=restserver (FQDN or IP)(connects on http)
RESTSERVER_PORT=8000

# --- SSH config ---
SSH_KEY_NAME=id_ed25519_sintinel (SSH to remote clients to take backups using this private key)

# --- Backup retention policy ---
BACKUP_RETENTION_POLICY=last:5,daily:5
#BACKUP_RETENTION_POLICY=last:5,daily:7,weekly:4,monthly:1" (example)
#→ keep 5 last snapshots, 7 daily, 4 weekly, 1 monthly

# --- Logging ---
LOG_LEVEL=INFO
LOG_MAX_MEGABYTES=10
LOG_BACKUP_COUNT=3

# --- User Output ---
HOST_RESTORE_DIR=/opt/sintinel/sintinel-data/restore (optional used for cleaner user outputs)

# --- PushGateway ---
PUSHGATEWAY_URL=https://me-prometheus.abramad.com:9091 (optional)
PUSHGATEWAY_JOB=(optional)
PUSHGATEWAY_INSTANCE=(optional)
PUSHGATEWAY_TARGET=(optional)
LABEL_TEAM=sysops